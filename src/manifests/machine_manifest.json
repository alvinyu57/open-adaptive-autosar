{
  "machine": {
    "shortName": "WSL_VM_Machine",
    "functionGroups": [
      {
        "name": "MachineFG",
        "states": ["Startup", "Running", "Restart", "Shutdown"],
        "initialState": "Startup"
      }
    ],
    "processes": [
      {
        "name": "HelloWorldProcess",
        "executablePath": "apps/01_hello_world/openaa_example_hello_world_runner",
        "executionManifest": "apps/01_hello_world/manifests/execution_manifest.json",
        "startupConfigs": [
          {
            "functionGroup": "MachineFG",
            "state": "Startup"
          }
        ]
      }
    ],
    "networkInterfaces": [
      {
        "name": "Eth0Connector",
        "type": "Ethernet",
        "endpoints": [
          {
            "name": "Eth0Endpoint",
            "address": "192.168.0.100",
            "netmask": "255.255.255.0"
          }
        ]
      }
    ],
    "os": {
      "name": "Ubuntu",
      "version": "22.04"
    }
  }
}

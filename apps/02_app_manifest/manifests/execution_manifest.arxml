<?xml version="1.0" encoding="UTF-8"?>
<AUTOSAR xmlns="http://autosar.org/schema/r4.0">
    <AR-PACKAGES>
        <AR-PACKAGE>
            <SHORT-NAME>OpenAA</SHORT-NAME>
            <AR-PACKAGES>
                <AR-PACKAGE>
                    <SHORT-NAME>Execution</SHORT-NAME>
                    <ELEMENTS>
                        <EXECUTION-MANIFEST>
                            <SHORT-NAME>ExecManifestDemo</SHORT-NAME>
                            <PROCESS-NAME>app_manifest_demo_process</PROCESS-NAME>
                            <APPLICATION-REF>/OpenAA/Applications/AppManifestDemo</APPLICATION-REF>
                            <STARTUP-CONFIGURATION>
                                <AUTO-START>true</AUTO-START>
                                <STARTUP-ORDER>10</STARTUP-ORDER>
                            </STARTUP-CONFIGURATION>
                            <STATE-DEPENDENCY>
                                <FUNCTION-GROUP>MachineFG</FUNCTION-GROUP>
                                <FUNCTION-GROUP-STATE>Startup</FUNCTION-GROUP-STATE>
                            </STATE-DEPENDENCY>
                            <TERMINATION-BEHAVIOR>
                                <TERMINATION-TIMEOUT-MS>2000</TERMINATION-TIMEOUT-MS>
                                <RESTART-ATTEMPTS>3</RESTART-ATTEMPTS>
                            </TERMINATION-BEHAVIOR>
                        </EXECUTION-MANIFEST>
                    </ELEMENTS>
                </AR-PACKAGE>
            </AR-PACKAGES>
        </AR-PACKAGE>
    </AR-PACKAGES>
</AUTOSAR>

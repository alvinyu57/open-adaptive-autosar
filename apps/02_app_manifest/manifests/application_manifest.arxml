<?xml version="1.0" encoding="UTF-8"?>
<AUTOSAR xmlns="http://autosar.org/schema/r4.0">
    <AR-PACKAGES>
        <AR-PACKAGE>
            <SHORT-NAME>OpenAA</SHORT-NAME>
            <AR-PACKAGES>
                <AR-PACKAGE>
                    <SHORT-NAME>Applications</SHORT-NAME>
                    <ELEMENTS>
                        <APPLICATION-MANIFEST>
                            <SHORT-NAME>AppManifestDemo</SHORT-NAME>
                            <APPLICATION-ID>apps.02_app_manifest.demo</APPLICATION-ID>
                            <EXECUTABLE-NAME>openaa_app_manifest_demo</EXECUTABLE-NAME>
                            <ARGUMENTS>
                                <ARGUMENT>--mode=demo</ARGUMENT>
                            </ARGUMENTS>
                            <ENVIRONMENT-VARIABLES>
                                <ENVIRONMENT-VARIABLE>
                                    <NAME>OPENAA_APP_PROFILE</NAME>
                                    <VALUE>app_manifest_demo</VALUE>
                                </ENVIRONMENT-VARIABLE>
                            </ENVIRONMENT-VARIABLES>
                            <PROVIDED-SERVICES>
                                <PROVIDED-SERVICE>
                                    <SERVICE-ID>apps.02.app_manifest.greeter</SERVICE-ID>
                                    <ENDPOINT>local://app-manifest-greeter</ENDPOINT>
                                </PROVIDED-SERVICE>
                            </PROVIDED-SERVICES>
                        </APPLICATION-MANIFEST>
                    </ELEMENTS>
                </AR-PACKAGE>
            </AR-PACKAGES>
        </AR-PACKAGE>
    </AR-PACKAGES>
</AUTOSAR>

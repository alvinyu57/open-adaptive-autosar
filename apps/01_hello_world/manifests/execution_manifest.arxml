<?xml version="1.0" encoding="UTF-8"?>
<AUTOSAR xmlns="http://autosar.org/schema/r25" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://autosar.org/schema/r25 AUTOSAR_00051.xsd">
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>HelloWorldExecutionManifest</SHORT-NAME>
      <ELEMENTS>
        <EXECUTABLE>
          <SHORT-NAME>HelloWorldProcessExecutable</SHORT-NAME>
          <REPORTING-BEHAVIOR>REPORTS-EXECUTION-STATE</REPORTING-BEHAVIOR>
        </EXECUTABLE>
        <PROCESS>
          <SHORT-NAME>HelloWorldProcess</SHORT-NAME>
          <EXECUTABLE-REF DEST="EXECUTABLE">/HelloWorldExecutionManifest/HelloWorldProcessExecutable</EXECUTABLE-REF>
          <STATE-DEPENDENT-STARTUP-CONFIGS>
            <STATE-DEPENDENT-STARTUP-CONFIG>
              <FUNCTION-GROUP-STATE-IREFS>
                <FUNCTION-GROUP-STATE-IN-FUNCTION-GROUP-SET-INSTANCE-REF>
                  <CONTEXT-MODE-DECLARATION-GROUP-PROTOTYPE-REF DEST="MODE-DECLARATION-GROUP-PROTOTYPE">/MachineManifest/MachineFG</CONTEXT-MODE-DECLARATION-GROUP-PROTOTYPE-REF>
                  <TARGET-MODE-DECLARATION-REF DEST="MODE-DECLARATION">/MachineManifest/MachineStates/Startup</TARGET-MODE-DECLARATION-REF>
                </FUNCTION-GROUP-STATE-IN-FUNCTION-GROUP-SET-INSTANCE-REF>
              </FUNCTION-GROUP-STATE-IREFS>
              <STARTUP-CONFIG-REF DEST="STARTUP-CONFIG">/HelloWorldExecutionManifest/HelloWorldStartupConfig</STARTUP-CONFIG-REF>
            </STATE-DEPENDENT-STARTUP-CONFIG>
          </STATE-DEPENDENT-STARTUP-CONFIGS>
        </PROCESS>
        <STARTUP-CONFIG>
          <SHORT-NAME>HelloWorldStartupConfig</SHORT-NAME>
          <TERMINATION-BEHAVIOR>processIsSelfTerminating</TERMINATION-BEHAVIOR>
        </STARTUP-CONFIG>
      </ELEMENTS>
    </AR-PACKAGE>
  </AR-PACKAGES>
</AUTOSAR>
